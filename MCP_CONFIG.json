{
  "mcpServers": [
    {
      "name": "wechat-aggregator",
      "description": "微信公众号聚合器 - 自动收集和管理高校社团公众号文章",
      "version": "1.0.0",
      "transport": "http",
      "baseUrl": "http://localhost:8000/api/mcp",
      "capabilities": {
        "tools": [
          {
            "name": "list_articles",
            "description": "获取文章列表，支持按公众号和时间筛选",
            "inputSchema": {
              "type": "object",
              "properties": {
                "skip": {
                  "type": "integer",
                  "description": "跳过数量(分页)",
                  "default": 0
                },
                "limit": {
                  "type": "integer",
                  "description": "返回数量",
                  "default": 50,
                  "minimum": 1,
                  "maximum": 200
                },
                "account_id": {
                  "type": "integer",
                  "description": "公众号ID(可选)"
                },
                "days": {
                  "type": "integer",
                  "description": "最近N天(可选)"
                }
              }
            }
          },
          {
            "name": "search_articles",
            "description": "在文章标题、摘要、作者和公众号名称中搜索关键词",
            "inputSchema": {
              "type": "object",
              "properties": {
                "keyword": {
                  "type": "string",
                  "description": "搜索关键词(必填)"
                },
                "skip": {
                  "type": "integer",
                  "description": "跳过数量(分页)",
                  "default": 0
                },
                "limit": {
                  "type": "integer",
                  "description": "返回数量",
                  "default": 50,
                  "minimum": 1,
                  "maximum": 200
                }
              },
              "required": ["keyword"]
            }
          },
          {
            "name": "get_article",
            "description": "获取单篇文章的完整信息",
            "inputSchema": {
              "type": "object",
              "properties": {
                "article_id": {
                  "type": "integer",
                  "description": "文章ID(必填)"
                }
              },
              "required": ["article_id"]
            }
          },
          {
            "name": "list_accounts",
            "description": "获取系统中所有已添加的公众号",
            "inputSchema": {
              "type": "object",
              "properties": {
                "skip": {
                  "type": "integer",
                  "description": "跳过数量(分页)",
                  "default": 0
                },
                "limit": {
                  "type": "integer",
                  "description": "返回数量",
                  "default": 50,
                  "minimum": 1,
                  "maximum": 200
                },
                "university_id": {
                  "type": "integer",
                  "description": "大学ID(预留字段,暂未实现)"
                }
              }
            }
          },
          {
            "name": "get_account",
            "description": "获取单个公众号的完整信息，包括最新文章",
            "inputSchema": {
              "type": "object",
              "properties": {
                "account_id": {
                  "type": "integer",
                  "description": "公众号ID(必填)"
                }
              },
              "required": ["account_id"]
            }
          },
          {
            "name": "list_universities",
            "description": "获取系统中所有大学列表(当前版本暂未实现)",
            "inputSchema": {
              "type": "object",
              "properties": {
                "skip": {
                  "type": "integer",
                  "description": "跳过数量(分页)",
                  "default": 0
                },
                "limit": {
                  "type": "integer",
                  "description": "返回数量",
                  "default": 50,
                  "minimum": 1,
                  "maximum": 200
                }
              }
            }
          },
          {
            "name": "get_university",
            "description": "获取单个大学的详细信息(当前版本暂未实现)",
            "inputSchema": {
              "type": "object",
              "properties": {
                "university_id": {
                  "type": "integer",
                  "description": "大学ID(必填)"
                }
              },
              "required": ["university_id"]
            }
          }
        ],
        "resources": [],
        "prompts": []
      },
      "examples": [
        "查一下最近7天的文章",
        "搜索包含招新的文章",
        "获取所有公众号列表",
        "查看公众号ID为5的最新文章",
        "搜索关键词为'春招'的文章"
      ]
    }
  ],
  "usage": {
    "naturalLanguageQueries": [
      {
        "query": "查一下最近7天的文章",
        "tool": "list_articles",
        "params": {
          "days": 7,
          "limit": 50
        }
      },
      {
        "query": "搜索包含招新的文章",
        "tool": "search_articles",
        "params": {
          "keyword": "招新",
          "limit": 20
        }
      },
      {
        "query": "获取所有公众号列表",
        "tool": "list_accounts",
        "params": {}
      },
      {
        "query": "查看文章ID为123的详情",
        "tool": "get_article",
        "params": {
          "article_id": 123
        }
      },
      {
        "query": "查看公众号ID为5的最新文章",
        "tool": "get_account",
        "params": {
          "account_id": 5
        }
      }
    ]
  }
}
